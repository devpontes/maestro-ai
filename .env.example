# ─────────────────────────────────────────────────────────────────────────────
#  Maestro AI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Web Scraping (Apify) ────────────────────────────────────────────────────
# Required by the `apify` skill.
# Get your token at: https://console.apify.com/account/integrations
APIFY_TOKEN=

# ─── Instagram Publishing ────────────────────────────────────────────────────
# Required by the `instagram-publisher` skill.
# See: skills/instagram-publisher/SKILL.md → Setup section for full instructions.

# Long-lived access token (valid 60 days) from Meta Graph API
INSTAGRAM_ACCESS_TOKEN=

# Your Instagram Business Account User ID
INSTAGRAM_USER_ID=

# imgBB API key for hosting images before publishing to Instagram
# Get your key at: https://api.imgbb.com/
IMGBB_API_KEY=

# ─── Email Sending (Resend) ──────────────────────────────────────────────────
# Required by the `resend` skill.
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=

# ─── Image Generation ────────────────────────────────────────────────────────
# Required by the `image-ai-generator` skill.
# Supported providers: openai, stability, fal
IMAGE_AI_PROVIDER=openai
IMAGE_AI_API_KEY=
